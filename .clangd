---
CompileFlags:
  Add:
    - -std=gnu11
    - -DVERSION="3.0"
    - -DLIBPREFIX="/usr/local/lib"
    - -DWEBEXTDIR="/usr/local/lib/surf"
    - -D_DEFAULT_SOURCE
    - -DWPE_ENABLE_XKB=1
    - -Isrc
    - -I/usr/include/wpe-webkit-2.0
    - -I/usr/include/wpe-webkit-2.0/wpe-platform
    - -I/usr/include/wpe-1.0
    - -I/usr/include/libsoup-3.0
    - -I/usr/include/pango-1.0
    - -I/usr/include/harfbuzz
    - -I/usr/include/cairo
    - -I/usr/include/pixman-1
    - -I/usr/include/fribidi
    - -I/usr/include/freetype2
    - -I/usr/include/libpng16
    - -I/usr/include/libdrm
    - -I/usr/include/glib-2.0
    - -I/usr/lib/glib-2.0/include
    - -I/usr/include/libmount
    - -I/usr/include/blkid
    - -I/usr/include/sysprof-6

Diagnostics:
  UnusedIncludes: None
